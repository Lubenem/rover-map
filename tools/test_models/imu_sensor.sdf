<?xml version="1.0" ?>
<sdf version="1.6">
  <model name="imu_sensor_test">
    <static>true</static>
    <pose>0 0 0.2 0 0 0</pose>
    <link name="base_link">
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.01</ixx>
          <iyy>0.01</iyy>
          <izz>0.01</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <sensor name="imu_sensor" type="imu">
        <always_on>true</always_on>
        <update_rate>200</update_rate>
        <visualize>false</visualize>
        <plugin name="imu_ros_plugin" filename="libgazebo_ros_imu_sensor.so">
          <robotNamespace>/</robotNamespace>
          <topicName>/imu</topicName>
          <frameName>imu_link</frameName>
          <gaussianNoise>0.0003</gaussianNoise>
        </plugin>
      </sensor>
    </link>
  </model>
</sdf>
